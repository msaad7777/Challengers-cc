# Stripe API Keys
# Copy this file to .env.local and fill in your values
# Get your keys from: https://dashboard.stripe.com/apikeys

# Test keys (safe to use for development)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Base URL for redirects
# Development: http://localhost:3000
# Production: https://challengerscc.ca
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Setup Instructions:
# 1. Go to https://dashboard.stripe.com/register (create account if needed)
# 2. Go to Developers > API keys
# 3. Copy "Secret key" to STRIPE_SECRET_KEY
# 4. Copy "Publishable key" to NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# 5. For production, use live keys and update NEXT_PUBLIC_BASE_URL

# ── NextAuth (C3H members portal) ──
# CRITICAL: all three required in production or sessions will be unstable
# (users will be logged out unexpectedly / across tabs).
#
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_URL must match your deployed URL exactly.
# GOOGLE_CLIENT_ID / SECRET from Google Cloud Console → Credentials → OAuth 2.0.
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://challengerscc.ca
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
