# ==========================================================================
# Catch-all guards — block any image / PDF / sensitive JSON at the repo
# ROOT. Files under /public/ are unaffected (that's the right place for
# images and document downloads we DO want shipped).
# ==========================================================================

# Block all images at the repo root (use /public/ for committed images)
/*.jpeg
/*.jpg
/*.png
/*.webp
/*.gif
/*.bmp
/*.svg
/*.heic
/*.tiff

# Block all PDFs at the repo root (use /public/documents/ for shareable PDFs)
/*.pdf

# Block n8n workflow exports + sponsor data dumps + any "previous" backups
/*Outreach*.json
/*Workflow*.json
/*workflow*.json
/*previous*.json
/*Sponsor*.json
/*sponsor*.json

# Block Mac/IDE noise
.idea/
.vscode/
*.swp
*.swo

# Block credential / key shapes regardless of name
service-account*.json
*-credentials*.json
*-key.json
*.p12
*.pfx
.env.production
.env.development
.env.staging
